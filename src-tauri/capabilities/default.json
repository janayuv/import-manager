{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the application.",
  "local": true,
  "windows": ["*"],
  "webviews": ["*"],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "tauri://localhost"
    ]
  },
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-exists",

    "fs:allow-copy-file",

    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }]
    }
  ]
}
