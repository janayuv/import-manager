{
  "name": "Import Manager",
  "private": true,
  "version": "0.2.1",
  "description": "Windows-only desktop application for managing import/export operations",
  "os": [
    "win32"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:tauri": "powershell -ExecutionPolicy Bypass -File scripts\\fix-installer-issues.ps1 && cross-env LIBSQLITE3_SYS_BUNDLED=1 tauri build",
    "clean": "rimraf node_modules dist src-tauri/target",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "format:rust": "cd src-tauri && cargo fmt",
    "type-check": "tsc --noEmit",
    "clean:tauri-cache": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force 'src-tauri/target','node_modules/.vite','dist' -ErrorAction SilentlyContinue\"",
    "security:gitleaks": "node scripts/gitleaks-scan.mjs",
    "security:full": "gitleaks detect --source . --no-banner --log-opts=--all",
    "prepare": "husky",
    "preview": "vite preview",
    "test:pw-install": "playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e:ci": "playwright install chromium && playwright test tests/ui-smoke.spec.ts tests/ui-workflows.spec.ts tests/ui-edge-cases.spec.ts tests/ui-data-integrity.spec.ts tests/ui-performance.spec.ts tests/ui-reliability.spec.ts tests/ui-operational-reliability.spec.ts tests/ui-database.spec.ts --project=chromium --workers=1",
    "test": "npm run test:unit && npm run test:e2e:ci",
    "test:ci": "npm run test:unit:coverage && npm run test:e2e:ci",
    "test:performance": "node scripts/check-performance-baselines.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "generate:drift-report": "tsx scripts/generate-drift-report.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-core": "^4.11.3",
    "cross-env": "^10.1.0",
    "detect-secrets": "^1.0.6",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prettier-plugin-toml": "^2.0.6",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-remove-console": "^2.2.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
